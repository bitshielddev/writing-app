{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": ["node", "electron"]
  },
  "include": [
    "src/contracts/**/*.ts",
    "src/domain/**/*.ts",
    "src/domain/**/*.tsx",
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/utility/**/*.ts"
  ],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/test"]
}
